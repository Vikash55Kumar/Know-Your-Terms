# Server Configuration
PORT=4000

# JWT Configuration
JWT_SECRET=your_random_long_secret_string_here
JWT_EXPIRES_IN=7d

# Firebase Service Account (Backend)
# Instructions:
#   1. Go to Firebase Console > Project Settings > Service Accounts
#   2. Click "Generate New Private Key" – a JSON file will download
#   3. Open the JSON file, copy its contents and minify it to a SINGLE LINE (no newlines)
#   4. Paste the single-line JSON string as the value below (no surrounding quotes needed)
# Example: FIREBASE_CONFIG1={"type":"service_account","project_id":"your-project",...}
FIREBASE_CONFIG1=

# Google Gemini API Key
# Instructions: Go to https://aistudio.google.com/ and create an API key
GEMINI_API_KEY=

# GetStream.io (for AI Chat Agent)
# Instructions: Go to https://getstream.io/, create an app, copy API Key and Secret
STREAM_API_KEY=
STREAM_API_SECRET=

# Indian Kanoon API (Legal Case Search)
# Instructions: Register at https://indiankanoon.org/ and request an API token
KANOON_API_KEY=

# Tavily Search API (for AI Agent web search)
# Instructions: Go to https://tavily.com/ and get your API key
TAVILY_API_KEY=

# Frontend URL (used for CORS – comma-separate multiple origins)
FRONTEND_URL=http://localhost:5173

# AI Model URL (optional – only needed if running the Python AI service separately)
# AI_MODEL_URL=http://localhost:5000

# Demo Mode – set to 'true' to use mock data for document extraction (no external calls)
ENABLE_DEMO_MODE=true
